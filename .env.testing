#                                                       Testing
# ······················································································································
# ======================================================================================================================
# -----------------------------------
#       APP
# -----------------------------------
TESTING_APP_ID=testing
TESTING_APP_NAME="GameHangar (TESTING)"
TESTING_APP_VERSION=0.0.1-dev
TESTING_APP_COMMIT_ID=
TESTING_APP_ENV=dev

# ||||||||||||||||
# SERVER
# ||||||||||||||||
TESTING_APP_SERVER_HOST=
TESTING_APP_SERVER_PORT=10000
TESTING_APP_SERVER_READ_TIMEOUT_SECONDS=15
TESTING_APP_SERVER_WRITE_TIMEOUT_SECONDS=15
TESTING_APP_SERVER_IDLE_TIMEOUT_SECONDS=60
TESTING_APP_SERVER_SHUTDOWN_GRACE_TIMEOUT_SECONDS=10
TESTING_APP_SERVER_MAX_HEADER_SIZE=8192

TESTING_APP_LOG_LEVEL=error
TESTING_APP_LOG_FILE=logs/app.testing.log

TESTING_APP_CORS_ALLOWED_ORIGINS="*"
TESTING_APP_CORS_ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"
TESTING_APP_CORS_ALLOWED_HEADERS="Origin,Content-Type,Authorization"
TESTING_APP_CORS_ALLOWED_CREDENTIALS=true

# ||||||||||||||||
# AUTH
# ||||||||||||||||
TESTING_AUTH_PUBLIC_KEY_PATH=conf/cert_public.pem
TESTING_AUTH_PRIVATE_KEY_PATH=conf/cert_private.pem

TESTING_AUTH_ADMIN_PUBLIC_KEY_PATH=conf/cert_admin_public.pem
TESTING_AUTH_ADMIN_PRIVATE_KEY_PATH=conf/cert_admin_private.pem

TESTING_AUTH_PASSWORD_MIN_LENGTH=6
TESTING_AUTH_PASSWORD_MAX_LENGTH=18
TESTING_AUTH_PASSWORD_UPPERCASE=true
TESTING_AUTH_PASSWORD_LOWERCASE=true
TESTING_AUTH_PASSWORD_DIGITS=true

TESTING_AUTH_PASSWORD_SPECIAL=true

# --------------------------------
# Database
# ---------------------------------------
# postgres://admin:admin@localhost:5432/game_hangar?sslmode=disable
# TODO: Create test db
TESTING_POSTGRES_DB=identity_test
TESTING_POSTGRES_CONNECTION_STRING=
TESTING_POSTGRES_HOST=localhost
TESTING_POSTGRES_PORT=5432
TESTING_POSTGRES_USER=admin
TESTING_POSTGRES_PASS=admin
TESTING_POSTGRES_SSL_MODE=disable
TESTING_POSTGRES_MAX_OPEN_CONNECTIONS=10
TESTING_POSTGRES_MAX_IDLE_CONNECTIONS=2
TESTING_POSTGRES_MAX_CONNECTION_LIFETIME_MINUTES=60
TESTING_POSTGRES_MAX_CONNECTION_IDLE_TIME_MINUTES=30
