func init() {
	err := godotenv.Load()
	if err != nil {
		panic(err.Error())
	}
	config := settings.NewConfig()
	switch config.Environment {
	case settings.EnvTesting:
		gin.SetMode(gin.TestMode)
	case settings.EnvDev, settings.EnvStaging:
		gin.SetMode(gin.DebugMode)
	default:
		gin.SetMode(gin.ReleaseMode)
	}
}

type User struct {
	Username string `bson:"username"`
	Password string `bson:"password"`
}

func RunServer() {
	config := settings.GetConfig()

	ctx, stop := signal.NotifyContext(context.Background(),
		syscall.SIGHUP,
		syscall.SIGINT,
		syscall.SIGTERM,
		syscall.SIGQUIT,
	)
	defer stop()

	router := gin.Default()
	err := router.SetTrustedProxies(config.TrustedProxies)
	if err != nil {
		panic(err.Error())
	}
	routes.InitRoutes(router)

	srv := &http.Server{
		Addr:    config.GetAddr(),
		Handler: router,
	}

	go func() {
		if err := srv.ListenAndServe(); err != nil && !errors.Is(err, http.ErrServerClosed) {
			log.Fatalf("Error while shutting down server, error: %s\n", err)
		}
	}()

	// ------------------ TODO
	uri := "mongodb://root:pass@localhost:27017"
	ctxDB, cancelDB := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancelDB()
	// Connect to MongoDBe

	//clientOpts := options.Client().
	//	ApplyURI(uri).
	//	SetMinPoolSize(5).
	//	SetMaxPoolSize(100).
	//	SetMaxConnIdleTime(30 * time.Minute)

	client, err := mongo.Connect(ctxDB, options.Client().ApplyURI(uri))
	if err != nil {
		log.Fatalf("failed to connect: %v", err)
	}

	defer func() {
		if err = client.Disconnect(ctx); err != nil {
			log.Fatalf("failed to disconnect: %v", err)
		}
	}()

	_ = client.Ping(ctx, readpref.Primary())

	// Ping the database to verify connection
	if err = client.Ping(ctx, nil); err != nil {
		log.Fatalf("failed to ping MongoDB: %w", err)
	}

	fmt.Println("✅ Connected to MongoDB!")

	// Use a filter to only select non-empty databases.
	//result, err := client.ListDatabaseNames(
	//	ctxDB,
	//	bson.D{{"empty", false}})
	//if err != nil {
	//	log.Fatalf("failed to list databases: %v", err)
	//}

	log.Println("💾 Databases:")
	for _, db := range result {
		fmt.Printf(db)
	}

	// Select database and collection
	collection := client.Database("myapp").Collection("users")

	// CRETTE INDEX
	//err = ensureIndexes(collection)
