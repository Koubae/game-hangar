	//	Options: options.Index().SetUnique(true), // enforce uniqueness
	//}
	//
	//_, err = collection.Indexes().CreateOne(ctxDB, indexModel)
	//if err != nil {
	//	log.Fatalf("failed to create unique index: %v", err)
	//}
	// ---

	// Create a new user
	// Hash the password with bcrypt
	rawPassword := "my_secret_pass"
	hashedPassword, err := bcrypt.GenerateFromPassword([]byte(rawPassword), bcrypt.DefaultCost)
	if err != nil {
		log.Fatalf("failed to hash password: %v", err)
	}

	username := "federico"
	newUser := User{Username: username, Password: string(hashedPassword)}

	// Insert the user
	//insertResult, err := collection.InsertOne(ctx, newUser)
	//if err != nil {
	//	log.Fatalf("failed to insert user: %v", err)
	//}

	insertResult, err := collection.InsertOne(ctx, newUser)
	if mongo.IsDuplicateKeyError(err) {
		log.Println("🚫 Username already exists!")
		var user User
		err = collection.FindOne(ctx, bson.M{"username": username}).Decode(&user)
		if err != nil {
			log.Printf("Error while getting user %s, errro: %v\n", username, err.Error())
		} else {
			log.Printf("User %s found with password: %s\n", user.Username, user.Password)
		}
	} else if err != nil {
		log.Fatalf("Insert failed: %v", err)
