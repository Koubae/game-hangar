# -----------------------------------
#       APP
# -----------------------------------
APP_NAME=GameHangar
APP_VERSION=0.0.1-dev
APP_COMMIT_ID=
APP_ENV=dev

# ||||||||||||||||
# SERVER
# ||||||||||||||||
APP_SERVER_HOST=
APP_SERVER_PORT=8080
APP_SERVER_READ_TIMEOUT_SECONDS=15
APP_SERVER_WRITE_TIMEOUT_SECONDS=15
APP_SERVER_IDLE_TIMEOUT_SECONDS=60
APP_SERVER_SHUTDOWN_GRACE_TIMEOUT_SECONDS=10
APP_SERVER_MAX_HEADER_SIZE=8192

APP_LOG_LEVEL=info
APP_LOG_FILE=logs/app.log

APP_CORS_ALLOWED_ORIGINS="*"
APP_CORS_ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"
APP_CORS_ALLOWED_HEADERS="Origin,Content-Type,Authorization"
APP_CORS_ALLOWED_CREDENTIALS=true

# ||||||||||||||||
# AUTH
# ||||||||||||||||

# ---------------------------------------
# Database
# ---------------------------------------
# postgres://admin:admin@localhost:5432/game_hangar?sslmode=disable
POSTGRES_DB=game_hangar
POSTGRES_CONNECTION_STRING=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASS=admin
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_OPEN_CONNECTIONS=10
POSTGRES_MAX_IDLE_CONNECTIONS=2
POSTGRES_MAX_CONNECTION_LIFETIME_MINUTES=60
POSTGRES_MAX_CONNECTION_IDLE_TIME_MINUTES=30
